#!/usr/bin/env bash

set -euo pipefail

case ${1:-fetch} in
    name)
        printf 'ICINGA\n'
        exit 0
        ;;
    fetch) ;;
    *) printf 'icinga adapter: expected name or fetch\n' >&2; exit 2 ;;
esac

[[ -n ${PULSE_ICINGA_URL:-} ]] || exit 10
[[ -n ${PULSE_ICINGA_USER:-} && -n ${PULSE_ICINGA_PASSWORD:-} ]] || {
    printf 'icinga adapter: URL is configured but credentials are incomplete\n' >&2
    exit 2
}
auth_user=$PULSE_ICINGA_USER
auth_password=$PULSE_ICINGA_PASSWORD
unset PULSE_ICINGA_PASSWORD PULSE_NAGIOS_PASSWORD
case $auth_user$auth_password in
    *$'\t'*|*$'\r'*|*$'\n'*)
        printf 'icinga adapter: credentials contain a control character\n' >&2
        exit 2
        ;;
esac
command -v curl >/dev/null 2>&1 || {
    printf 'icinga adapter: curl is required\n' >&2
    exit 2
}
command -v jq >/dev/null 2>&1 || {
    printf 'icinga adapter: jq is required\n' >&2
    exit 2
}

previous_umask=$(umask)
umask 077
auth_file=$(mktemp "${TMPDIR:-/tmp}/pulse-icinga-auth.XXXXXX") || {
    umask "$previous_umask"
    printf 'icinga adapter: could not create a private curl config\n' >&2
    exit 2
}
umask "$previous_umask"
cleanup() {
    rm -f -- "$auth_file"
}
trap cleanup EXIT
trap 'exit 130' HUP INT TERM
escaped_user=$(printf '%s' "$auth_user" | sed 's/\\/\\\\/g; s/"/\\"/g')
escaped_password=$(printf '%s' "$auth_password" | sed 's/\\/\\\\/g; s/"/\\"/g')
printf 'user = "%s:%s"\n' "$escaped_user" "$escaped_password" > "$auth_file"
auth_user=
auth_password=

curl_args=(
    --fail
    --silent
    --show-error
    --connect-timeout "${PULSE_CONNECT_TIMEOUT:-3}"
    --max-time "${PULSE_MAX_TIME:-10}"
    --config "$auth_file"
    --get
)
if [[ ${PULSE_ICINGA_INSECURE:-0} == 1 ]]; then
    curl_args+=(--insecure)
fi

curl "${curl_args[@]}" \
    --data-urlencode 'filter=service.last_hard_state!=ServiceOK' \
    --data-urlencode 'attrs=display_name' \
    --data-urlencode 'attrs=host_name' \
    --data-urlencode 'attrs=last_hard_state' \
    --data-urlencode 'attrs=last_state_change' \
    --data-urlencode 'attrs=last_check_result' \
    "${PULSE_ICINGA_URL%/}/v1/objects/services" \
    | jq -r '
        def clean: tostring | gsub("[\\t\\r\\n]+"; " ");
        def clean_or_dash: clean | if length == 0 then "-" else . end;
        def severity:
            if . == 1 then "WARN"
            elif . == 2 then "CRIT"
            elif . == 3 then "UNKNOWN"
            else "UNKNOWN"
            end;
        (if (.results | type) != "array"
         then error("icinga response is missing the results array")
         else .results[] end) as $result
        | (if ($result.attrs | type) != "object"
           then error("icinga service result is missing attrs")
           else $result.attrs end) as $a
        | if ($a.last_hard_state | type) != "number"
          then error("icinga service result has no numeric last_hard_state")
          elif ($a.host_name | type) != "string"
          then error("icinga service result has no string host_name")
          elif ($a.last_state_change | type) != "number"
          then error("icinga service result has no numeric last_state_change")
          else $a end
        | select(($a.last_hard_state // 0) > 0)
        | [
            "ICINGA",
            ($a.last_hard_state | severity),
            ($a.host_name | clean_or_dash),
            (($a.display_name // ($result.name | split("!") | .[1:] | join("!")) // "service") | clean_or_dash),
            (($a.last_check_result.output // "") | clean_or_dash),
            (($a.last_state_change // 0) | floor | tostring)
          ]
        | @tsv
    '
