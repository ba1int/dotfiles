#!/usr/bin/env bash

set -euo pipefail

case ${1:-fetch} in
    name)
        printf 'NAGIOS\n'
        exit 0
        ;;
    fetch) ;;
    *) printf 'nagios adapter: expected name or fetch\n' >&2; exit 2 ;;
esac

[[ -n ${PULSE_NAGIOS_URL:-} ]] || exit 10
[[ -n ${PULSE_NAGIOS_USER:-} && -n ${PULSE_NAGIOS_PASSWORD:-} ]] || {
    printf 'nagios adapter: URL is configured but credentials are incomplete\n' >&2
    exit 2
}
auth_user=$PULSE_NAGIOS_USER
auth_password=$PULSE_NAGIOS_PASSWORD
unset PULSE_ICINGA_PASSWORD PULSE_NAGIOS_PASSWORD
case $auth_user$auth_password in
    *$'\t'*|*$'\r'*|*$'\n'*)
        printf 'nagios adapter: credentials contain a control character\n' >&2
        exit 2
        ;;
esac
command -v curl >/dev/null 2>&1 || {
    printf 'nagios adapter: curl is required\n' >&2
    exit 2
}
command -v jq >/dev/null 2>&1 || {
    printf 'nagios adapter: jq is required\n' >&2
    exit 2
}

previous_umask=$(umask)
umask 077
auth_file=$(mktemp "${TMPDIR:-/tmp}/pulse-nagios-auth.XXXXXX") || {
    umask "$previous_umask"
    printf 'nagios adapter: could not create a private curl config\n' >&2
    exit 2
}
umask "$previous_umask"
cleanup() {
    rm -f -- "$auth_file"
}
trap cleanup EXIT
trap 'exit 130' HUP INT TERM
escaped_user=$(printf '%s' "$auth_user" | sed 's/\\/\\\\/g; s/"/\\"/g')
escaped_password=$(printf '%s' "$auth_password" | sed 's/\\/\\\\/g; s/"/\\"/g')
printf 'user = "%s:%s"\n' "$escaped_user" "$escaped_password" > "$auth_file"
auth_user=
auth_password=

curl --fail --silent --show-error \
    --connect-timeout "${PULSE_CONNECT_TIMEOUT:-3}" \
    --max-time "${PULSE_MAX_TIME:-10}" \
    --config "$auth_file" \
    --get \
    --data-urlencode 'query=servicelist' \
    --data-urlencode 'details=true' \
    "$PULSE_NAGIOS_URL" \
    | jq -r '
        def clean: tostring | gsub("[\\t\\r\\n]+"; " ");
        def clean_or_dash: clean | if length == 0 then "-" else . end;
        def severity:
            if . == 1 then "WARN"
            elif . == 2 then "CRIT"
            elif . == 3 then "UNKNOWN"
            else "UNKNOWN"
            end;
        (if ((.data | type) != "object") or
             ((.data.servicelist | type) != "object")
         then error("nagios response is missing the data.servicelist object")
         else .data.servicelist end)
        | to_entries[]
        | .key as $host
        | .value
        | to_entries[]
        | .key as $service
        | .value as $s
        | if ($s | type) != "object"
          then error("nagios service result is not an object")
          elif ($s.has_been_checked | type) != "boolean"
          then error("nagios service result has no boolean has_been_checked")
          elif ($s.last_hard_state | type) != "number"
          then error("nagios service result has no numeric last_hard_state")
          else $s end
        | select(($s.has_been_checked // false) and (($s.last_hard_state // 0) > 0))
        | [
            "NAGIOS",
            ($s.last_hard_state | severity),
            (($s.host_name // $host) | clean_or_dash),
            (($s.description // $service) | clean_or_dash),
            (((($s.plugin_output // "") +
                (if (($s.long_plugin_output // "") | length) > 0
                 then " / " + $s.long_plugin_output else "" end))) | clean_or_dash),
            (((($s.last_state_change // 0) / 1000) | floor) | tostring)
          ]
        | @tsv
    '
