// Protocol Ink / named operations desk
// Optional one-left, two-right layout for dispatcher-style work.

layout {
    pane size=1 borderless=true {
        plugin location="zellij:tab-bar" {
            hide_swap_layout_indication true
        }
    }
    pane split_direction="horizontal" {
        pane name="01 / DISPATCH" size="60%"
        pane split_direction="vertical" {
            pane name="02 / SHELL"
            pane name="03 / WATCH"
        }
    }
}
