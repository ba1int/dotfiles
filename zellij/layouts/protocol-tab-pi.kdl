// Protocol Ink / Pi operations desk
// Pi owns the large left pane; two clean shells share the right column.

layout {
    pane size=1 borderless=true {
        plugin location="zellij:tab-bar" {
            hide_swap_layout_indication true
        }
    }
    pane split_direction="vertical" {
        pane name="01 / PI" size="60%" command="pi" focus=true
        pane split_direction="horizontal" {
            pane name="02 / SHELL"
            pane name="03 / SHELL"
        }
    }
}
