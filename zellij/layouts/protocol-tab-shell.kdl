// Protocol Ink / shell operations desk
// The same dispatcher geometry with three clean interactive shells.

layout {
    pane size=1 borderless=true {
        plugin location="zellij:tab-bar" {
            hide_swap_layout_indication true
        }
    }
    pane split_direction="vertical" {
        pane name="01 / SHELL" size="60%" focus=true
        pane split_direction="horizontal" {
            pane name="02 / SHELL"
            pane name="03 / SHELL"
        }
    }
}
