#!/bin/sh
set -eu

remote_target() {
    if [ "${MONITORING_LAB_REMOTE+x}" = x ]; then
        [ -n "$MONITORING_LAB_REMOTE" ] || return 1
        printf '%s\n' "$MONITORING_LAB_REMOTE"
        return
    fi

    remote_file="${XDG_CONFIG_HOME:-$HOME/.config}/monitoring-lab/remote"
    [ -r "$remote_file" ] || return 1

    remote=$(
        sed \
            -e 's/\r$//' \
            -e '/^[[:space:]]*#/d' \
            -e '/^[[:space:]]*$/d' \
            -e 's/^[[:space:]]*//' \
            -e 's/[[:space:]]*$//' \
            "$remote_file" | sed -n '1p'
    )
    [ -n "$remote" ] || return 1
    printf '%s\n' "$remote"
}

quote_remote_arg() {
    printf "'"
    printf '%s' "$1" | sed "s/'/'\\\\''/g"
    printf "'"
}

outer_zellij_locked=0

restore_outer_zellij() {
    if [ "$outer_zellij_locked" -eq 1 ]; then
        zellij action switch-mode normal >/dev/null 2>&1 || true
        outer_zellij_locked=0
    fi
}

run_remote() {
    remote=$1
    shift

    case $remote in
        -*|*[[:space:]]*)
            printf 'lab: invalid remote destination: %s\n' "$remote" >&2
            printf '%s\n' 'Use a single SSH destination such as operator@example-host.' >&2
            return 2
            ;;
    esac

    command -v ssh >/dev/null 2>&1 || {
        printf '%s\n' 'lab: ssh is required for remote mode.' >&2
        return 1
    }

    remote_command='exec "$HOME/.local/bin/lab"'
    for argument do
        quoted_argument=$(quote_remote_arg "$argument")
        remote_command="$remote_command $quoted_argument"
    done

    enter_workstation=0
    if [ "$#" -eq 0 ]; then
        enter_workstation=1
        if [ -n "${ZELLIJ:-}" ] && command -v zellij >/dev/null 2>&1; then
            if zellij action switch-mode locked >/dev/null 2>&1; then
                outer_zellij_locked=1
                trap 'restore_outer_zellij' EXIT HUP INT TERM
            else
                printf '%s\n' 'lab: warning: could not lock the outer Zellij session.' >&2
            fi
        fi
    fi

    if [ "$enter_workstation" -eq 1 ]; then
        printf 'lab: connecting to %s; local web tunnels stay open for this session.\n' "$remote"
        if ssh \
            -o ExitOnForwardFailure=yes \
            -L 127.0.0.1:15665:127.0.0.1:15665 \
            -L 127.0.0.1:18081:127.0.0.1:18081 \
            -tt -- "$remote" "$remote_command"
        then
            exit_status=0
        else
            exit_status=$?
        fi
    elif ssh -tt -- "$remote" "$remote_command"; then
        exit_status=0
    else
        exit_status=$?
    fi

    restore_outer_zellij
    trap - EXIT HUP INT TERM
    return "$exit_status"
}

if remote=$(remote_target); then
    run_remote "$remote" "$@"
    exit $?
fi

find_lab_home() {
    if [ -n "${MONITORING_LAB_HOME:-}" ]; then
        printf '%s\n' "$MONITORING_LAB_HOME"
        return
    fi

    for candidate in \
        "$HOME/Documents/monitoring-lab" \
        "$HOME/monitoring-lab"
    do
        if [ -x "$candidate/bin/lab" ]; then
            printf '%s\n' "$candidate"
            return
        fi
    done

    return 1
}

lab_home=$(find_lab_home) || {
    printf '%s\n' 'lab: monitoring-lab was not found.' >&2
    printf '%s\n' 'Set MONITORING_LAB_HOME or clone it to ~/Documents/monitoring-lab.' >&2
    exit 1
}

if [ ! -x "$lab_home/bin/lab" ]; then
    printf 'lab: launcher is not executable: %s/bin/lab\n' "$lab_home" >&2
    exit 1
fi

exec "$lab_home/bin/lab" "$@"
