#!/usr/bin/env bash

set -euo pipefail

OPS_PROGRAM=hop
ops_share=${PROTOCOL_OPS_SHARE:-"${XDG_DATA_HOME:-$HOME/.local/share}/protocol-ops"}
script_dir=$(CDPATH= cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
if [[ ! -r $ops_share/runtime.sh ]]; then
    ops_share="$script_dir/../lib/protocol-ops"
fi
[[ -r $ops_share/runtime.sh ]] || {
    printf 'hop: shared runtime missing; rerun install-terminal.sh\n' >&2
    exit 1
}
. "$ops_share/runtime.sh"
. "$ops_share/inventory.sh"
. "$ops_share/fzf.sh"

usage() {
    cat <<'EOF'
Usage: hop [options] [query ...]

Search an inventory and SSH to the selected host.

Options:
  --print             Print the selection instead of connecting.
  --select HOST       Select an exact inventory alias without opening fzf.
  --list              Print the validated inventory as TSV.
  --inventory FILE    Use an explicit host inventory.
  -h, --help          Show this help.

Inventory precedence:
  1. --inventory FILE
  2. OPS_INVENTORY
  3. HOP_INVENTORY (legacy compatibility)
  4. ${XDG_CONFIG_HOME:-$HOME/.config}/hop/hosts.tsv

The exact TSV header is: name<TAB>environment<TAB>role<TAB>site
EOF
}

preview_record() {
    local host record environment role site ssh_config hostname user port route
    host=${1:-}
    case $host in
        ''|*[!A-Za-z0-9._-]*) return 1 ;;
    esac
    [[ $host =~ ^[A-Za-z0-9] ]] || return 1
    [[ -n ${HOP_RECORDS_FILE:-} && -r $HOP_RECORDS_FILE ]] || return 1

    record=$(ops_inventory_find "$HOP_RECORDS_FILE" "$host")
    [[ -n $record ]] || return 1
    IFS=$'\t' read -r host environment role site <<< "$record"

    ssh_config=$("$OPS_SSH_BIN" -G -- "$host" 2>/dev/null || true)
    hostname=$(awk '$1 == "hostname" { print $2; exit }' <<< "$ssh_config")
    user=$(awk '$1 == "user" { print $2; exit }' <<< "$ssh_config")
    port=$(awk '$1 == "port" { print $2; exit }' <<< "$ssh_config")
    route=$(awk '$1 == "proxyjump" { print $2; exit }' <<< "$ssh_config")
    [[ -n $hostname ]] || hostname=$host
    [[ -n $user ]] || user=${USER:-user}
    [[ -n $port ]] || port=22
    [[ -n $route && $route != none ]] || route=direct

    OPS_COLOR=${OPS_COLOR:-1}
    OPS_LABEL_WIDTH=13
    ops_field ALIAS "$host" paper
    ops_field ENVIRONMENT "$environment"
    ops_field SITE "$site"
    ops_field ROLE "$role"
    printf '\n'
    ops_field TARGET "$user@$hostname:$port"
    ops_field ROUTE "$route"
    ops_field COMMAND "ssh $host" accent
}

if [[ ${1:-} == --_preview ]]; then
    [[ $# -eq 2 ]] || exit 2
    preview_record "$2"
    exit
fi

inventory_flag=
print_only=0
list_only=0
selected_host=
queries=()
query_count=0

while [[ $# -gt 0 ]]; do
    case $1 in
        --print) print_only=1 ;;
        --list) list_only=1 ;;
        --select)
            [[ $# -ge 2 ]] || ops_die '--select requires a host alias'
            [[ -n $2 ]] || ops_die '--select requires a nonempty host alias'
            selected_host=$2
            shift
            ;;
        --inventory)
            [[ $# -ge 2 ]] || ops_die '--inventory requires a file'
            [[ -n $2 ]] || ops_die '--inventory requires a nonempty file path'
            inventory_flag=$2
            shift
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        --)
            shift
            while [[ $# -gt 0 ]]; do
                queries+=("$1")
                query_count=$((query_count + 1))
                shift
            done
            break
            ;;
        -*) ops_die "unknown option: $1" ;;
        *)
            queries+=("$1")
            query_count=$((query_count + 1))
            ;;
    esac
    shift
done

[[ -z $selected_host || $query_count -eq 0 ]] \
    || ops_die 'a query cannot be combined with --select'

inventory=$(ops_inventory_path "$inventory_flag")
ops_tmp_open
records_file="$OPS_TMPDIR/hosts.tsv"
choices_file="$OPS_TMPDIR/choices.tsv"
ops_inventory_normalize "$inventory" "$records_file"

if [[ $list_only -eq 1 ]]; then
    printf 'name\tenvironment\trole\tsite\n'
    cat "$records_file"
    exit 0
fi

if [[ -n $selected_host ]]; then
    ops_inventory_has "$records_file" "$selected_host" \
        || ops_die "host is not present in the inventory: $selected_host"
else
    ops_need "$OPS_FZF_BIN"
    record_count=$(ops_inventory_count "$records_file")
    ops_fzf_base "SSH HOST INDEX / ${record_count} RECORDS" "$record_count"

    if (( OPS_COLUMNS < 64 )); then
        header='ENV   HOST'
        while IFS=$'\t' read -r host environment role site; do
            printf '%s\t%s %s %s %s\t%-5s %s\n' \
                "$host" "$environment" "$site" "$role" "$host" \
                "$environment" "$host"
        done < "$records_file" > "$choices_file"
    else
        header='ENV   SITE       ROLE             HOST'
        while IFS=$'\t' read -r host environment role site; do
            printf '%s\t%s %s %s %s\t%-5s %-10s %-16s %s\n' \
                "$host" "$environment" "$site" "$role" "$host" \
                "$environment" "$site" "$role" "$host"
        done < "$records_file" > "$choices_file"
    fi
    header="${header}"$'\n''ENTER SSH  CTRL-/ PREVIEW  ESC CANCEL'

    query=
    if (( query_count > 0 )); then
        for query_part in "${queries[@]}"; do
            query="${query}${query:+ }${query_part}"
        done
    fi

    self_path="$script_dir/$(basename -- "${BASH_SOURCE[0]}")"
    printf -v preview_command '%q --_preview {1}' "$self_path"
    export HOP_RECORDS_FILE="$records_file"
    export OPS_COLOR=1

    fzf_args=(
        "${OPS_FZF_BASE[@]}"
        '--delimiter=\t'
        '--with-nth=3'
        '--nth=1,2'
        '--prompt=FILTER / '
        "--header=$header"
        "--query=$query"
        "--preview=$preview_command"
        '--preview-label= HOST RECORD '
        "--preview-window=$OPS_PREVIEW_WINDOW"
        '--bind=ctrl-/:toggle-preview'
    )

    set +e
    selected_line=$(FZF_DEFAULT_OPTS='' \
        "$OPS_FZF_BIN" "${fzf_args[@]}" < "$choices_file")
    fzf_status=$?
    set -e
    case $fzf_status in
        0) ;;
        1|130) exit 0 ;;
        *) ops_die "fzf exited with status $fzf_status" ;;
    esac
    [[ -n $selected_line ]] || exit 0
    selected_host=${selected_line%%$'\t'*}
    ops_inventory_has "$records_file" "$selected_host" \
        || ops_die 'fzf returned a host outside the inventory'
fi

if [[ $print_only -eq 1 ]]; then
    printf '%s\n' "$selected_host"
    exit 0
fi

ops_need "$OPS_SSH_BIN"
ops_tmp_cleanup
unset HOP_RECORDS_FILE OPS_COLOR
exec "$OPS_SSH_BIN" -- "$selected_host"
