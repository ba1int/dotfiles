#!/usr/bin/env bash

set -euo pipefail

OPS_PROGRAM=peek
ops_share=${PROTOCOL_OPS_SHARE:-"${XDG_DATA_HOME:-$HOME/.local/share}/protocol-ops"}
script_dir=$(CDPATH= cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
if [[ ! -r $ops_share/runtime.sh ]]; then
    ops_share="$script_dir/../lib/protocol-ops"
fi
[[ -r $ops_share/runtime.sh ]] || {
    printf 'peek: shared runtime missing; rerun install-terminal.sh\n' >&2
    exit 1
}
. "$ops_share/runtime.sh"
. "$ops_share/inventory.sh"

usage() {
    cat <<'EOF'
Usage: peek [options] [HOST]

Render one inventory-backed host record using a single read-only SSH session.
With no HOST, hop opens first.

Options:
  --inventory FILE     Use an explicit host inventory.
  --checks-dir DIR     Read common.tsv and optional ROLE.tsv checks from DIR.
  --no-monitoring      Skip the optional pulse summary.
  -h, --help           Show this help.

Check directory precedence:
  1. --checks-dir DIR
  2. PEEK_CHECKS_DIR
  3. ${OPS_CONFIG_HOME}/peek.d when it exists
  4. the installed Protocol Ops defaults

Check files use: id<TAB>label<TAB>command
Commands are trusted local configuration and run read-only through one SSH call.
EOF
}

validate_checks_file() {
    local source target
    source=$1
    target=$2
    LC_ALL=C awk -F '\t' -v OFS='\t' -v program="$OPS_PROGRAM" '
        { sub(/\r$/, "", $0) }
        NR == 1 {
            if ($0 != "id\tlabel\tcommand") {
                printf "%s: check file %s has an invalid header\n", program, FILENAME > "/dev/stderr"
                fatal = 1
                exit 2
            }
            next
        }
        NF != 3 || $1 == "" || $2 == "" || $3 == "" {
            printf "%s: check file %s line %d must have three nonempty tab-separated fields\n", program, FILENAME, NR > "/dev/stderr"
            bad = 1
            next
        }
        $1 !~ /^[A-Za-z0-9][A-Za-z0-9._-]*$/ {
            printf "%s: unsafe check id in %s line %d: %s\n", program, FILENAME, NR, $1 > "/dev/stderr"
            bad = 1
            next
        }
        $1 ~ /[[:cntrl:]]/ || $2 ~ /[[:cntrl:]]/ || $3 ~ /[[:cntrl:]]/ {
            printf "%s: control character in %s line %d\n", program, FILENAME, NR > "/dev/stderr"
            bad = 1
            next
        }
        { print $1, $2, $3; records++ }
        END {
            if (fatal || bad) exit 2
            if (records == 0) {
                printf "%s: check file contains no records: %s\n", program, FILENAME > "/dev/stderr"
                exit 2
            }
        }
    ' "$source" >> "$target"
}

inventory_flag=
checks_flag=
monitoring=1
host=

while [[ $# -gt 0 ]]; do
    case $1 in
        --inventory)
            [[ $# -ge 2 ]] || ops_die '--inventory requires a file'
            [[ -n $2 ]] || ops_die '--inventory requires a nonempty file path'
            inventory_flag=$2
            shift
            ;;
        --checks-dir)
            [[ $# -ge 2 ]] || ops_die '--checks-dir requires a directory'
            [[ -n $2 ]] || ops_die '--checks-dir requires a nonempty directory'
            checks_flag=$2
            shift
            ;;
        --no-monitoring) monitoring=0 ;;
        -h|--help)
            usage
            exit 0
            ;;
        -*) ops_die "unknown option: $1" ;;
        *)
            [[ -z $host ]] || ops_die 'only one host may be inspected'
            host=$1
            ;;
    esac
    shift
done

inventory=$(ops_inventory_path "$inventory_flag")
ops_tmp_open
records_file="$OPS_TMPDIR/hosts.tsv"
checks_file="$OPS_TMPDIR/checks.tsv"
remote_script="$OPS_TMPDIR/remote.sh"
results_file="$OPS_TMPDIR/results.tsv"
ops_inventory_normalize "$inventory" "$records_file"

if [[ -z $host ]]; then
    ops_need hop
    host=$(OPS_INVENTORY="$inventory" hop --print)
    [[ -n $host ]] || exit 0
fi
ops_inventory_has "$records_file" "$host" \
    || ops_die "host is not present in the inventory: $host"

record=$(ops_inventory_find "$records_file" "$host")
IFS=$'\t' read -r host environment role site <<< "$record"

if [[ -n $checks_flag ]]; then
    checks_dir=$checks_flag
elif [[ -n ${PEEK_CHECKS_DIR:-} ]]; then
    checks_dir=$PEEK_CHECKS_DIR
elif [[ -d $OPS_CONFIG_HOME/peek.d ]]; then
    checks_dir="$OPS_CONFIG_HOME/peek.d"
else
    checks_dir="$ops_share/peek.d"
fi
[[ -d $checks_dir ]] || ops_die "check directory does not exist: $checks_dir"
[[ -r $checks_dir/common.tsv ]] \
    || ops_die "check directory is missing readable common.tsv: $checks_dir"

: > "$checks_file"
validate_checks_file "$checks_dir/common.tsv" "$checks_file"
case $role in
    common) role_file= ;;
    [A-Za-z0-9]* )
        case $role in
            *[!A-Za-z0-9._\ -]*)
                ops_die "inventory role cannot map to a portable profile filename: $role"
                ;;
            *) role_file="$checks_dir/$role.tsv" ;;
        esac
        ;;
    *) ops_die "inventory role cannot map to a portable profile filename: $role" ;;
esac
if [[ -n $role_file && ( -e $role_file || -L $role_file ) ]]; then
    [[ -r $role_file ]] || ops_die "role check profile is not readable: $role_file"
    validate_checks_file "$role_file" "$checks_file"
fi

duplicate_id=$(awk -F '\t' 'seen[$1]++ { print $1; exit }' "$checks_file")
[[ -z $duplicate_id ]] || ops_die "duplicate check id across profile files: $duplicate_id"

{
    cat <<'REMOTE'
#!/bin/sh
peek_check() {
    peek_id=$1
    peek_command=$2
    peek_value=$(sh -c "$peek_command" 2>&1)
    peek_status=$?
    peek_value=$(printf '%s\n' "$peek_value" | LC_ALL=C awk '
        NR == 1 { gsub(/[[:cntrl:]]/, " "); print; exit }
    ')
    [ -n "$peek_value" ] || peek_value='-'
    printf '%s\t%s\t%s\n' "$peek_id" "$peek_status" "$peek_value"
}
REMOTE
    while IFS=$'\t' read -r check_id _ check_command; do
        quoted_command=$(printf '%s' "$check_command" | sed "s/'/'\\\\''/g")
        printf "peek_check '%s' '%s'\n" "$check_id" "$quoted_command"
    done < "$checks_file"
} > "$remote_script"

ops_need "$OPS_SSH_BIN"
icinga_password_set=0
nagios_password_set=0
icinga_password=
nagios_password=
if [[ -n ${PULSE_ICINGA_PASSWORD+x} ]]; then
    icinga_password_set=1
    icinga_password=$PULSE_ICINGA_PASSWORD
fi
if [[ -n ${PULSE_NAGIOS_PASSWORD+x} ]]; then
    nagios_password_set=1
    nagios_password=$PULSE_NAGIOS_PASSWORD
fi
unset PULSE_ICINGA_PASSWORD PULSE_NAGIOS_PASSWORD
set +e
"$OPS_SSH_BIN" -T -- "$host" sh -s \
    < "$remote_script" > "$results_file" 2> "$OPS_TMPDIR/ssh.err"
ssh_status=$?
set -e
if [[ $ssh_status -ne 0 ]]; then
    ssh_error=$(LC_ALL=C awk 'NR == 1 { gsub(/[[:cntrl:]]/, " "); print; exit }' \
        "$OPS_TMPDIR/ssh.err")
    ops_die "SSH collection failed for $host${ssh_error:+: $ssh_error}"
fi

if ! LC_ALL=C awk -F '\t' -v program="$OPS_PROGRAM" '
    NF != 3 || $1 !~ /^[A-Za-z0-9][A-Za-z0-9._-]*$/ || $2 !~ /^[0-9]+$/ {
        printf "%s: malformed remote check result on line %d\n", program, NR > "/dev/stderr"
        bad = 1
    }
    END { exit bad ? 2 : 0 }
' "$results_file"; then
    exit 1
fi

ssh_config=$("$OPS_SSH_BIN" -G -- "$host" 2>/dev/null || true)
hostname=$(awk '$1 == "hostname" { print $2; exit }' <<< "$ssh_config")
user=$(awk '$1 == "user" { print $2; exit }' <<< "$ssh_config")
port=$(awk '$1 == "port" { print $2; exit }' <<< "$ssh_config")
route=$(awk '$1 == "proxyjump" { print $2; exit }' <<< "$ssh_config")
[[ -n $hostname ]] || hostname=$host
[[ -n $user ]] || user=${USER:-user}
[[ -n $port ]] || port=22
[[ -n $route && $route != none ]] || route=direct

monitor_state=${PEEK_MONITORING_STATE:-skipped}
unset PEEK_MONITORING_STATE
if [[ $monitoring -eq 1 && $monitor_state == skipped ]] \
    && command -v pulse >/dev/null 2>&1; then
    if [[ $icinga_password_set -eq 1 ]]; then
        PULSE_ICINGA_PASSWORD=$icinga_password
        export PULSE_ICINGA_PASSWORD
    fi
    if [[ $nagios_password_set -eq 1 ]]; then
        PULSE_NAGIOS_PASSWORD=$nagios_password
        export PULSE_NAGIOS_PASSWORD
    fi
    monitor_state=$(OPS_INVENTORY="$inventory" pulse --summary "$host" 2>/dev/null \
        || printf 'unavailable')
fi
unset PULSE_ICINGA_PASSWORD PULSE_NAGIOS_PASSWORD
icinga_password=
nagios_password=

printf '\n'
ops_heading "HOST RECORD / $host"
printf '%s\n' '────────────────────────────────────────────────────────'
OPS_LABEL_WIDTH=15
ops_field ENVIRONMENT "$environment"
ops_field SITE "$site"
ops_field ROLE "$role"
ops_field TARGET "$user@$hostname:$port"
ops_field ROUTE "$route"
case $monitor_state in
    *CRIT*) monitor_tone=critical ;;
    *ERROR*|*WARN*|*UNKNOWN*) monitor_tone=warning ;;
    *OK*) monitor_tone=ok ;;
    *) monitor_tone=meta ;;
esac
ops_field MONITORING "$monitor_state" "$monitor_tone"
printf '\n'
ops_heading "REMOTE CHECKS / $(awk 'END { print NR + 0 }' "$checks_file")"
while IFS=$'\t' read -r check_id check_label _; do
    result=$(awk -F '\t' -v wanted="$check_id" '$1 == wanted { print; exit }' \
        "$results_file")
    if [[ -z $result ]]; then
        ops_field "$check_label" 'missing result' warning
        continue
    fi
    IFS=$'\t' read -r _ check_status check_value <<< "$result"
    if [[ $check_status -eq 0 ]]; then
        ops_field "$check_label" "$check_value"
    else
        ops_field "$check_label" "$check_value (exit $check_status)" warning
    fi
done < "$checks_file"
printf '%s\n' '────────────────────────────────────────────────────────'
ops_field PROFILE "$checks_dir" meta
