#!/usr/bin/env bash
set -Eeuo pipefail

readonly RVI_NVIM="${RVI_NVIM:-nvim}"
readonly RVI_RECENT_LIMIT=6
rvi_tmpdir=
rvi_browse_result=
rvi_search_result=
rvi_search_type=
rvi_recent_rows=

RVI_SSH_ARGS=(
    -T
    -o ClearAllForwardings=yes
    -o ConnectTimeout=10
    -o ForwardAgent=no
    -o RequestTTY=no
    -o UpdateHostKeys=no
)

usage() {
    cat <<'EOF'
Usage: rvi [--read-only] [HOST [/absolute/path]]

Open a remote file in local Neovim without installing editor configuration on
the target. Normal files use Neovim's native SSH transport. Protected files
are staged locally, shown as a diff, and installed atomically with remote
passwordless sudo only after confirmation.

Options:
  -R, --read-only  Never write to the target.
  -h, --help       Show this help.
EOF
}

rvi_die() {
    printf 'rvi: %s\n' "$*" >&2
    exit 1
}

rvi_cleanup_local() {
    [[ -z ${rvi_tmpdir:-} ]] || rm -rf -- "$rvi_tmpdir"
}

rvi_validate_host() {
    [[ $1 =~ ^([A-Za-z0-9][A-Za-z0-9._-]{0,62}@)?[A-Za-z0-9][A-Za-z0-9._-]{0,252}$ ]]
}

rvi_validate_path() {
    [[ $1 == /* ]] || return 1
    [[ $1 == / ]] && return 0
    [[ $1 != *//* ]] || return 1
    [[ $1 =~ ^/[A-Za-z0-9._+/@:=,-]+(/[A-Za-z0-9._+/@:=,-]+)*/?$ ]]
}

rvi_netrw_url() {
    printf 'scp://%s//%s' "$1" "${2#/}"
}

rvi_list_hosts() {
    local file
    while IFS= read -r file; do
        awk '
            tolower($1) == "host" {
                for (i = 2; i <= NF; i++) {
                    if ($i !~ /[*?!]/) print $i
                }
            }
        ' "$file"
    done < <(
        find "$HOME/.ssh" -maxdepth 3 -type f \
            \( -name config -o -name '*.conf' \) -print 2>/dev/null
    ) | LC_ALL=C sort -u
}

rvi_recent_file() {
    printf '%s/rvi/hosts/%s.recent' \
        "${XDG_STATE_HOME:-$HOME/.local/state}" "$1"
}

rvi_recent_write() {
    local host=$1 content=${2:-} file directory temporary old_umask
    file=$(rvi_recent_file "$host")
    directory=$(dirname -- "$file")

    if [[ -z $content ]]; then
        rm -f -- "$file"
        return 0
    fi

    mkdir -p -- "$directory"
    chmod 700 "$(dirname -- "$directory")" "$directory"
    old_umask=$(umask)
    umask 077
    temporary=$(mktemp "$directory/.recent.XXXXXX")
    printf '%s\n' "$content" > "$temporary"
    chmod 600 "$temporary"
    mv -f -- "$temporary" "$file"
    umask "$old_umask"
}

rvi_recent_record() {
    local host=$1 path=$2 file candidate content count=1
    local -a entries
    rvi_validate_host "$host" || return 0
    rvi_validate_path "$path" || return 0
    entries=("$path")
    file=$(rvi_recent_file "$host")

    if [[ -r $file ]]; then
        while IFS= read -r candidate; do
            [[ $candidate != "$path" ]] || continue
            rvi_validate_path "$candidate" || continue
            entries+=("$candidate")
            (( count += 1 ))
            (( count >= RVI_RECENT_LIMIT )) && break
        done < "$file"
    fi

    content=$(printf '%s\n' "${entries[@]}")
    rvi_recent_write "$host" "$content"
}

rvi_recent_load() {
    local host=$1 file path valid current rows= row
    local -a paths=()
    rvi_recent_rows=
    file=$(rvi_recent_file "$host")
    [[ -r $file ]] || return 0

    while IFS= read -r path; do
        rvi_validate_path "$path" || continue
        paths+=("$path")
        (( ${#paths[@]} >= RVI_RECENT_LIMIT )) && break
    done < "$file"
    (( ${#paths[@]} > 0 )) || { rvi_recent_write "$host" ''; return 0; }

    valid=$(ssh "${RVI_SSH_ARGS[@]}" "$host" sh -s -- "${paths[@]}" <<'REMOTE_RECENT'
sudo_ready=0
sudo -n true >/dev/null 2>&1 && sudo_ready=1
for path do
    if [ -f "$path" ] || { [ "$sudo_ready" -eq 1 ] && sudo -n test -f "$path"; }; then
        printf '%s\n' "$path"
    fi
done
REMOTE_RECENT
    ) || return 0

    current=$(printf '%s\n' "${paths[@]}")
    [[ $valid == "$current" ]] || rvi_recent_write "$host" "$valid"
    [[ -n $valid ]] || return 0
    while IFS= read -r path; do
        printf -v row 'FAST\t\t\t\t\t%s' "$path"
        rows+="$row"$'\n'
    done <<< "$valid"
    rvi_recent_rows=${rows%$'\n'}
}

rvi_remote_list() {
    local host=$1 directory=$2
    ssh "${RVI_SSH_ARGS[@]}" "$host" sh -s -- "$directory" <<'REMOTE_LIST'
directory=$1

list_directory() {
    find -L "$directory" -mindepth 1 -maxdepth 1 \
        -printf '%y\t%m\t%u:%g\t%s\t%TY-%Tm-%Td %TH:%TM\t%f\n' 2>/dev/null || true
}

if sudo -n true >/dev/null 2>&1; then
    sudo -n test -d "$directory" || exit 1
    sudo -n sh -c '
        directory=$1
        find -L "$directory" -mindepth 1 -maxdepth 1 \
            -printf '\''%y\t%m\t%u:%g\t%s\t%TY-%Tm-%Td %TH:%TM\t%f\n'\'' 2>/dev/null || true
    ' sh "$directory"
else
    [ -d "$directory" ] || exit 1
    list_directory
fi
REMOTE_LIST
}

rvi_filter_listing() {
    local tab=$'\t'
    awk -F "$tab" -v OFS="$tab" '
        NF == 6 && $6 ~ /^[A-Za-z0-9._+@:=,-]+$/ {
            $1 = $1 == "d" ? "DIR" : ($1 == "f" ? "FILE" : "LINK")
            print
        }
    ' | LC_ALL=C sort -t $'\t' -k1,1 -k6,6
}

rvi_remote_search() {
    local host=$1 scope=$2
    ssh "${RVI_SSH_ARGS[@]}" "$host" sh -s -- "$scope" <<'REMOTE_SEARCH'
scope=$1

search_tree() {
    find -P "$scope" \
        \( -path /proc -o -path /sys -o -path /dev \) -prune -o \
        -mindepth 1 \( -type d -o -type f -o -type l \) \
        -printf '%y\t%m\t%u:%g\t%s\t%TY-%Tm-%Td %TH:%TM\t%p\n' 2>/dev/null || true
}

if sudo -n true >/dev/null 2>&1; then
    sudo -n test -d "$scope" || exit 1
    sudo -n sh -c '
        scope=$1
        find -P "$scope" \
            \( -path /proc -o -path /sys -o -path /dev \) -prune -o \
            -mindepth 1 \( -type d -o -type f -o -type l \) \
            -printf '\''%y\t%m\t%u:%g\t%s\t%TY-%Tm-%Td %TH:%TM\t%p\n'\'' 2>/dev/null || true
    ' sh "$scope"
else
    [ -d "$scope" ] || exit 1
    search_tree
fi
REMOTE_SEARCH
}

rvi_filter_search() {
    local tab=$'\t'
    awk -F "$tab" -v OFS="$tab" '
        NF == 6 && $6 ~ /^\/[A-Za-z0-9._+\/@:=,-]+$/ {
            $1 = $1 == "d" ? "DIR" : ($1 == "f" ? "FILE" : "LINK")
            print
            fflush()
        }
    '
}

rvi_select_host() {
    local selection
    command -v fzf >/dev/null 2>&1 || rvi_die 'fzf is required for the host picker'
    [[ -t 0 && -t 2 ]] || rvi_die 'the host picker needs an interactive terminal'
    selection=$(rvi_list_hosts | fzf \
        --height=70% --layout=reverse --border=sharp \
        --prompt='SSH HOST  ' \
        --header='RVI / REMOTE INDEX  ·  enter select  ·  esc close' \
        --color='bg:#151714,bg+:#242824,fg:#ded7c7,fg+:#f0eadb,hl:#7ea3ae,hl+:#e88978,border:#49504b,prompt:#7ea3ae,pointer:#e88978,marker:#d9df72,header:#858780' \
    ) || return 1
    printf '%s' "$selection"
}

rvi_search() {
    local host=$1 scope=$2 selection type mode owner size modified path
    selection=$(rvi_remote_search "$host" "$scope" | rvi_filter_search | fzf \
        --height=85% --layout=reverse --border=sharp \
        --delimiter=$'\t' --with-nth=1,2,3,5,6 \
        --prompt='REMOTE FIND  ' \
        --header="RVI FIND / $host:$scope  ·  recursive names  ·  esc back" \
        --color='bg:#151714,bg+:#242824,fg:#ded7c7,fg+:#f0eadb,hl:#7ea3ae,hl+:#e88978,border:#49504b,prompt:#7ea3ae,pointer:#e88978,marker:#d9df72,header:#858780' \
    ) || return 1

    IFS=$'\t' read -r type mode owner size modified path <<< "$selection"
    [[ -n $path ]] || return 1
    rvi_search_type=$type
    rvi_search_result=$path
}

rvi_browse() {
    local host=$1 directory=${2:-/} raw listing output key selection type mode owner size modified name fast_hint=
    command -v fzf >/dev/null 2>&1 || rvi_die 'fzf is required for remote browsing'
    [[ -t 0 && -t 1 ]] || rvi_die 'remote browsing needs an interactive terminal'
    [[ $directory == / ]] || directory=${directory%/}

    while :; do
        raw=$(rvi_remote_list "$host" "$directory") \
            || rvi_die "could not list $host:$directory"
        listing=$(printf '%s\n' "$raw" | rvi_filter_listing)
        fast_hint=
        if [[ $directory == / ]]; then
            rvi_recent_load "$host"
            if [[ -n $rvi_recent_rows ]]; then
                listing=$(printf '%s\n%s' "$rvi_recent_rows" "$listing")
                fast_hint='fast access  ·  '
            fi
        fi
        if [[ $directory != / ]]; then
            listing=$(printf 'DIR\t----\t-\t-\t-\t..\n%s' "$listing")
        fi

        output=$(printf '%s\n' "$listing" | fzf \
            --height=85% --layout=reverse --border=sharp \
            --delimiter=$'\t' --with-nth=1,2,3,5,6 \
            --expect=ctrl-f \
            --prompt='REMOTE FS  ' \
            --header="RVI / $host:$directory  ·  ${fast_hint}type filter  ·  ctrl-f recursive  ·  enter open  ·  esc close" \
            --color='bg:#151714,bg+:#242824,fg:#ded7c7,fg+:#f0eadb,hl:#7ea3ae,hl+:#e88978,border:#49504b,prompt:#7ea3ae,pointer:#e88978,marker:#d9df72,header:#858780' \
        ) || return 1

        if [[ $output == *$'\n'* ]]; then
            key=${output%%$'\n'*}
            selection=${output#*$'\n'}
        else
            key=
            selection=$output
        fi

        if [[ $key == ctrl-f ]]; then
            if rvi_search "$host" "$directory"; then
                if [[ $rvi_search_type == DIR ]]; then
                    directory=$rvi_search_result
                else
                    rvi_browse_result=$rvi_search_result
                    return 0
                fi
            fi
            continue
        fi

        if [[ $selection == FAST$'\t'* ]]; then
            rvi_browse_result=${selection##*$'\t'}
            return 0
        fi

        IFS=$'\t' read -r type mode owner size modified name <<< "$selection"
        if [[ $name == .. ]]; then
            directory=$(dirname -- "$directory")
        elif [[ $type == DIR ]]; then
            [[ $directory == / ]] && directory=/$name || directory=$directory/$name
        else
            [[ $directory == / ]] && rvi_browse_result=/$name || rvi_browse_result=$directory/$name
            return 0
        fi
    done
}

rvi_complete_path() {
    local host=$1 current=${2:-/} directory base type mode owner size modified name suffix
    [[ $current == /* ]] || return 0
    if [[ $current == */ ]]; then
        directory=${current%/}
        [[ -n $directory ]] || directory=/
        base=
    else
        directory=${current%/*}
        [[ -n $directory ]] || directory=/
        base=${current##*/}
    fi

    while IFS=$'\t' read -r type mode owner size modified name; do
        [[ $name == "$base"* ]] || continue
        suffix=
        [[ $type == DIR ]] && suffix=/
        [[ $directory == / ]] \
            && printf '/%s%s\n' "$name" "$suffix" \
            || printf '%s/%s%s\n' "$directory" "$name" "$suffix"
    done < <(rvi_remote_list "$host" "$directory" 2>/dev/null | rvi_filter_listing)
}

rvi_color_enabled() {
    [[ -t 1 && ${TERM:-dumb} != dumb && ${NO_COLOR:-} == '' ]]
}

rvi_tone() {
    local tone=$1 text=$2 code=''
    if rvi_color_enabled; then
        case $tone in
            teal)  code='38;2;126;163;174' ;;
            coral) code='38;2;216;121;103' ;;
            meta)  code='38;2;132;132;125' ;;
            rule)  code='38;2;73;76;72' ;;
        esac
    fi
    if [[ -n $code ]]; then
        printf '\033[%sm%s\033[0m' "$code" "$text"
    else
        printf '%s' "$text"
    fi
}

rvi_heading() {
    printf '\n'
    rvi_tone teal "$1"
    rvi_tone rule '  ────────────────────────────────────────'
    printf '\n'
}

rvi_field() {
    rvi_tone meta "$(printf '%-12s' "$1")"
    printf '%s\n' "$2"
}

rvi_emit_apply_script() {
    cat <<'REMOTE_SCRIPT'
set -eu

requested=$1
upload=$2
expected_crc=$3
expected_bytes=$4
workdir=
resolved=
backup=
replaced=0

cleanup() {
    status=$?
    trap - EXIT HUP INT TERM
    if [ "$status" -ne 0 ] && [ "$replaced" -eq 1 ] && [ -n "$backup" ] && [ -e "$backup" ]; then
        mv -f -- "$backup" "$resolved" 2>/dev/null || true
    fi
    [ -z "$workdir" ] || rm -rf -- "$workdir"
    rm -f -- "$upload"
    exit "$status"
}
trap cleanup EXIT
trap 'exit 129' HUP
trap 'exit 130' INT
trap 'exit 143' TERM

resolved=$(realpath -- "$requested")
[ -f "$resolved" ] || { printf 'rvi: target is not a regular file\n' >&2; exit 1; }
[ -f "$upload" ] || { printf 'rvi: staged upload is missing\n' >&2; exit 1; }

if links=$(stat -c '%h' -- "$resolved" 2>/dev/null); then
    :
else
    links=$(stat -f '%l' -- "$resolved")
fi
[ "$links" -eq 1 ] || {
    printf 'rvi: refusing to replace a file with %s hard links\n' "$links" >&2
    exit 1
}

set -- $(cksum < "$resolved")
[ "$1" = "$expected_crc" ] && [ "$2" = "$expected_bytes" ] || {
    printf 'rvi: remote file changed while it was being edited; nothing applied\n' >&2
    exit 1
}

directory=$(dirname -- "$resolved")
workdir=$(mktemp -d "$directory/.rvi.XXXXXX")
backup=$workdir/original
candidate=$workdir/candidate

cp -a -- "$resolved" "$backup"
cp -a -- "$resolved" "$candidate"
cat -- "$upload" > "$candidate"

set -- $(cksum < "$resolved")
[ "$1" = "$expected_crc" ] && [ "$2" = "$expected_bytes" ] || {
    printf 'rvi: remote file changed just before apply; nothing applied\n' >&2
    exit 1
}

mv -f -- "$candidate" "$resolved"
replaced=1

cmp -s -- "$upload" "$resolved" || {
    printf 'rvi: verification failed; restoring original\n' >&2
    exit 1
}

rm -f -- "$backup"
replaced=0
exit 0
REMOTE_SCRIPT
}

rvi_main() {
    local read_only=0 host path probe kind can_read can_write sudo_ready remote_user
    local read_mode original edited crc bytes answer remote_upload status

    if [[ ${1:-} == --complete-hosts ]]; then
        rvi_list_hosts
        return 0
    fi
    if [[ ${1:-} == --complete-path ]]; then
        [[ $# -eq 3 ]] || return 0
        rvi_validate_host "$2" || return 0
        rvi_complete_path "$2" "$3"
        return 0
    fi

    while [[ $# -gt 0 ]]; do
        case $1 in
            -R|--read-only) read_only=1; shift ;;
            -h|--help) usage; return 0 ;;
            --) shift; break ;;
            -*) rvi_die "unknown option: $1" ;;
            *) break ;;
        esac
    done
    [[ $# -le 2 ]] || { usage >&2; return 2; }
    if [[ $# -eq 0 ]]; then
        host=$(rvi_select_host) || return 0
        path=/
    elif [[ $# -eq 1 ]]; then
        host=$1
        path=/
    else
        host=$1
        path=$2
    fi

    rvi_validate_host "$host" || rvi_die "unsafe SSH destination: $host"
    rvi_validate_path "$path" || rvi_die "path must be absolute and contain only portable configuration-path characters"
    command -v "$RVI_NVIM" >/dev/null 2>&1 || rvi_die "Neovim not found: $RVI_NVIM"
    command -v ssh >/dev/null 2>&1 || rvi_die 'ssh not found'

    probe=$(ssh "${RVI_SSH_ARGS[@]}" "$host" sh -s -- "$path" <<'REMOTE_PROBE'
set -eu
path=$1
readable=0; writable=0; sudo_ready=0
[ -r "$path" ] && readable=1
[ -w "$path" ] && writable=1
sudo -n true >/dev/null 2>&1 && sudo_ready=1

if [ -e "$path" ]; then
    if [ -d "$path" ]; then kind=directory; elif [ -f "$path" ]; then kind=file; else kind=other; fi
elif [ "$sudo_ready" -eq 1 ] && sudo -n test -e "$path"; then
    if sudo -n test -d "$path"; then kind=directory; elif sudo -n test -f "$path"; then kind=file; else kind=other; fi
else
    printf 'missing|0|0|%s|%s\n' "$sudo_ready" "$(id -un)"
    exit 0
fi

printf '%s|%s|%s|%s|%s\n' "$kind" "$readable" "$writable" "$sudo_ready" "$(id -un)"
REMOTE_PROBE
    ) || rvi_die "could not inspect $host:$path"

    IFS='|' read -r kind can_read can_write sudo_ready remote_user <<< "$probe"
    [[ $kind != missing ]] || rvi_die "remote path does not exist: $host:$path (use 'rvi $host' to browse)"
    [[ $kind == file || $kind == directory ]] || rvi_die "remote path is neither a regular file nor a directory"

    if [[ $kind == directory ]]; then
        if rvi_browse "$host" "$path"; then
            if [[ $read_only == 1 ]]; then
                rvi_main --read-only "$host" "$rvi_browse_result"
            else
                rvi_main "$host" "$rvi_browse_result"
            fi
        fi
        return 0
    fi

    if [[ $read_only == 1 && $can_read == 1 ]]; then
        rvi_heading 'REMOTE EDIT / READ ONLY'
        rvi_field HOST "$host"
        rvi_field SSH "$remote_user"
        rvi_field PATH "$path"
        if "$RVI_NVIM" -R "$(rvi_netrw_url "$host" "$path")"; then
            rvi_recent_record "$host" "$path"
            return 0
        else
            return $?
        fi
    fi

    if [[ $read_only == 0 && $can_read == 1 && $can_write == 1 ]]; then
        rvi_heading 'REMOTE EDIT / USER'
        rvi_field HOST "$host"
        rvi_field SSH "$remote_user"
        rvi_field PATH "$path"
        rvi_field WRITE 'direct SSH'
        if "$RVI_NVIM" "$(rvi_netrw_url "$host" "$path")"; then
            rvi_recent_record "$host" "$path"
            return 0
        else
            return $?
        fi
    fi

    [[ $sudo_ready == 1 ]] || {
        if [[ $read_only == 1 ]]; then
            rvi_die 'file is not readable by the SSH user and passwordless sudo is unavailable'
        fi
        rvi_die 'file is protected and passwordless sudo is unavailable'
    }

    original=$(mktemp -d "${TMPDIR:-/tmp}/rvi.XXXXXX")
    rvi_tmpdir=$original
    trap rvi_cleanup_local EXIT
    edited=$original/edit
    mkdir -m 700 "$edited"
    edited=$edited/$(basename -- "$path")

    if [[ $can_read == 1 ]]; then
        read_mode=user
        ssh "${RVI_SSH_ARGS[@]}" "$host" "cat -- '$path'" > "$original/original"
    else
        read_mode=sudo
        ssh "${RVI_SSH_ARGS[@]}" "$host" "sudo -n cat -- '$path'" > "$original/original"
    fi
    cp "$original/original" "$edited"

    rvi_heading 'REMOTE EDIT / PRIVILEGED'
    rvi_field HOST "$host"
    rvi_field SSH "$remote_user"
    rvi_field PATH "$path"
    rvi_field READ "$read_mode"
    rvi_field APPLY 'sudo -n · diff + confirmation'

    if [[ $read_only == 1 ]]; then
        if "$RVI_NVIM" -R "$edited"; then
            rvi_recent_record "$host" "$path"
            return 0
        else
            return $?
        fi
    elif "$RVI_NVIM" "$edited"; then
        rvi_recent_record "$host" "$path"
    else
        return $?
    fi
    if cmp -s "$original/original" "$edited"; then
        rvi_tone meta 'NO CHANGE'
        printf '\n'
        return 0
    fi

    printf '\n'
    diff -u --label "$host:$path (before)" --label "$host:$path (edited)" \
        "$original/original" "$edited" || status=$?
    [[ ${status:-1} -eq 1 ]] || rvi_die 'could not produce a diff'

    [[ -r /dev/tty && -w /dev/tty ]] || rvi_die 'an interactive terminal is required to approve privileged writes'
    printf '\n'
    rvi_tone coral 'APPLY REMOTE CHANGE? [y/N] '
    IFS= read -r answer < /dev/tty
    [[ $answer == y || $answer == Y || $answer == yes || $answer == YES ]] || {
        rvi_tone meta 'CANCELLED'
        printf '\n'
        return 0
    }

    read -r crc bytes _ < <(cksum < "$original/original")
    remote_upload=$(ssh "${RVI_SSH_ARGS[@]}" "$host" \
        'set -eu; umask 077; upload=$(mktemp /tmp/rvi.XXXXXX); trap '\''rm -f -- "$upload"'\'' EXIT; cat > "$upload"; printf "%s\n" "$upload"; trap - EXIT' \
        < "$edited") || rvi_die 'could not stage the edited file on the target'
    [[ $remote_upload == /tmp/rvi.* ]] || rvi_die 'target returned an invalid staging path'

    if ! rvi_emit_apply_script | ssh "${RVI_SSH_ARGS[@]}" "$host" \
        "sudo -n sh -s -- '$path' '$remote_upload' '$crc' '$bytes'"; then
        ssh "${RVI_SSH_ARGS[@]}" "$host" "rm -f -- '$remote_upload'" >/dev/null 2>&1 || true
        rvi_die 'remote apply failed; the original was retained or restored'
    fi

    rvi_tone teal 'APPLIED'
    printf '  %s:%s\n' "$host" "$path"
}

if [[ ${BASH_SOURCE[0]} == "$0" ]]; then
    rvi_main "$@"
fi
