#!/usr/bin/env bash

set -euo pipefail

OPS_PROGRAM=kb
ops_share=${PROTOCOL_OPS_SHARE:-"${XDG_DATA_HOME:-$HOME/.local/share}/protocol-ops"}
script_dir=$(CDPATH= cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
if [[ ! -r $ops_share/runtime.sh ]]; then
    ops_share="$script_dir/../lib/protocol-ops"
fi
[[ -r $ops_share/runtime.sh ]] || {
    printf 'kb: shared runtime missing; rerun install-terminal.sh\n' >&2
    exit 1
}
. "$ops_share/runtime.sh"
. "$ops_share/fzf.sh"

usage() {
    cat <<'EOF'
Usage: kb [options] [query ...]

Search a configured Markdown cheatsheet folder and open the selected note.

Options:
  --root DIR          Use DIR for this invocation.
  --set-root DIR      Persist DIR in the machine-local Protocol Ops config.
  --print             Print the selected absolute path instead of opening it.
  --select PATH       Select an exact root-relative path without opening fzf.
  --list              List indexed notes as TSV without opening fzf.
  -h, --help          Show this help.

Root precedence:
  1. --root DIR
  2. KB_ROOT
  3. ${OPS_CONFIG_HOME}/kb-root

Set KB_EDITOR to one executable name or path to override VISUAL/EDITOR.
For Obsidian-specific opening, point KB_EDITOR at a small wrapper script.
EOF
}

kb_has_control() {
    local LC_ALL
    LC_ALL=C
    [[ $1 =~ [[:cntrl:]] ]]
}

canonical_root() {
    local candidate
    candidate=$1
    [[ -d $candidate ]] || ops_die "knowledge root is not a directory: $candidate"
    candidate=$(CDPATH= cd -- "$candidate" && pwd -P)
    ! kb_has_control "$candidate" \
        || ops_die 'knowledge root contains a control character'
    printf '%s\n' "$candidate"
}

persist_root() {
    local root config_file temporary previous_umask
    root=$(canonical_root "$1")
    config_file="$OPS_CONFIG_HOME/kb-root"
    mkdir -p "$OPS_CONFIG_HOME"
    temporary="$OPS_CONFIG_HOME/.kb-root.$$"
    previous_umask=$(umask)
    umask 077
    printf '%s\n' "$root" > "$temporary"
    chmod 0600 "$temporary"
    mv "$temporary" "$config_file"
    umask "$previous_umask"
    printf 'kb: root set to %s\n' "$root"
    if [[ -n ${KB_ROOT:-} ]]; then
        ops_warn 'KB_ROOT still overrides the saved root in this shell'
    fi
}

file_epoch() {
    stat -c '%Y' "$1" 2>/dev/null || stat -f '%m' "$1" 2>/dev/null
}

format_date() {
    date -d "@$1" '+%Y-%m-%d' 2>/dev/null \
        || date -r "$1" '+%Y-%m-%d' 2>/dev/null \
        || printf -- '-'
}

preview_note() {
    local id record epoch updated title relative note
    id=${1:-}
    [[ $id =~ ^[0-9]+$ ]] || return 1
    [[ -n ${KB_META_FILE:-} && -r $KB_META_FILE ]] || return 1
    [[ -n ${KB_PREVIEW_DIR:-} && -f $KB_PREVIEW_DIR/$id ]] || return 1
    record=$(awk -F '\t' -v wanted="$id" '$1 == wanted { print; exit }' \
        "$KB_META_FILE")
    [[ -n $record ]] || return 1
    IFS=$'\t' read -r id epoch updated title relative <<< "$record"
    note="$KB_PREVIEW_DIR/$id"

    OPS_COLOR=${OPS_COLOR:-1}
    OPS_LABEL_WIDTH=11
    ops_field TITLE "$title" paper
    ops_field UPDATED "$updated"
    ops_field PATH "$relative" accent
    printf '\n'
    if command -v bat >/dev/null 2>&1; then
        bat --color=always --paging=never --style=plain \
            --line-range=:300 -- "$note"
    else
        sed -n '1,300p' "$note"
    fi
}

if [[ ${1:-} == --_preview ]]; then
    [[ $# -eq 2 ]] || exit 2
    preview_note "$2"
    exit
fi

root_flag=
set_root=
print_only=0
list_only=0
select_relative=
queries=()
query_count=0

while [[ $# -gt 0 ]]; do
    case $1 in
        --root)
            [[ $# -ge 2 ]] || ops_die '--root requires a directory'
            [[ -n $2 ]] || ops_die '--root requires a nonempty directory'
            root_flag=$2
            shift
            ;;
        --set-root)
            [[ $# -ge 2 ]] || ops_die '--set-root requires a directory'
            [[ -n $2 ]] || ops_die '--set-root requires a nonempty directory'
            set_root=$2
            shift
            ;;
        --print) print_only=1 ;;
        --list) list_only=1 ;;
        --select)
            [[ $# -ge 2 ]] || ops_die '--select requires a root-relative path'
            [[ -n $2 ]] || ops_die '--select requires a nonempty root-relative path'
            select_relative=$2
            shift
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        --)
            shift
            while [[ $# -gt 0 ]]; do
                queries+=("$1")
                query_count=$((query_count + 1))
                shift
            done
            break
            ;;
        -*) ops_die "unknown option: $1" ;;
        *)
            queries+=("$1")
            query_count=$((query_count + 1))
            ;;
    esac
    shift
done

if [[ -n $set_root ]]; then
    [[ -z $root_flag && -z $select_relative && $list_only -eq 0 \
        && $print_only -eq 0 && $query_count -eq 0 ]] \
        || ops_die '--set-root cannot be combined with search options'
    persist_root "$set_root"
    exit 0
fi
[[ -z $select_relative || $query_count -eq 0 ]] \
    || ops_die 'a query cannot be combined with --select'

if [[ -n $root_flag ]]; then
    root=$(canonical_root "$root_flag")
elif [[ -n ${KB_ROOT:-} ]]; then
    root=$(canonical_root "$KB_ROOT")
else
    config_file="$OPS_CONFIG_HOME/kb-root"
    [[ -r $config_file ]] || ops_die \
        "knowledge root is not configured; run: kb --set-root /path/to/Cheatsheets"
    IFS= read -r root < "$config_file" || true
    config_lines=$(awk 'END { print NR + 0 }' "$config_file")
    [[ -n $root && $config_lines -eq 1 ]] \
        || ops_die "knowledge root config must contain exactly one nonempty line: $config_file"
    case $root in
        /*) ;;
        *) ops_die "saved knowledge root must be absolute: $config_file" ;;
    esac
    root=$(canonical_root "$root")
fi

ops_need rg
ops_tmp_open
meta_file="$OPS_TMPDIR/notes.tsv"
sorted_file="$OPS_TMPDIR/notes-sorted.tsv"
choices_file="$OPS_TMPDIR/choices.tsv"
preview_dir="$OPS_TMPDIR/preview"
paths_file="$OPS_TMPDIR/paths"
mkdir -p "$preview_dir"
: > "$meta_file"

set +e
rg --files -0 "$root" -g '*.md' -g '*.markdown' > "$paths_file"
rg_status=$?
set -e
case $rg_status in
    0|1) ;;
    *) ops_die "could not completely scan the knowledge root: $root" ;;
esac

note_count=0
while IFS= read -r -d '' note_path; do
    [[ $note_path == /* ]] || note_path="$root/$note_path"
    [[ -f $note_path ]] || continue
    if [[ $root == / ]]; then
        relative=${note_path#/}
    else
        relative=${note_path#"$root"/}
    fi
    if kb_has_control "$relative"; then
        ops_warn 'skipping a note path containing a control character'
        continue
    fi
    epoch=$(file_epoch "$note_path") || {
        ops_warn "could not read modification time: $relative"
        continue
    }
    updated=$(format_date "$epoch")
    title=$(LC_ALL=C awk '
        NR <= 120 && /^#[[:space:]]+/ {
            sub(/^#[[:space:]]+/, "")
            gsub(/[[:cntrl:]]/, " ")
            print
            exit
        }
        NR > 120 { exit }
    ' "$note_path")
    if [[ -z $title ]]; then
        title=$(basename -- "$relative")
        title=${title%.*}
    fi
    title=$(printf '%s' "$title" | LC_ALL=C awk \
        '{ gsub(/[[:cntrl:]]/, " "); print }')

    note_count=$((note_count + 1))
    ln -s "$note_path" "$preview_dir/$note_count"
    printf '%s\t%s\t%s\t%s\t%s\n' \
        "$note_count" "$epoch" "$updated" "$title" "$relative" >> "$meta_file"
done < "$paths_file"

(( note_count > 0 )) \
    || ops_die "knowledge root contains no Markdown notes: $root"
LC_ALL=C sort -t $'\t' -k2,2nr -k5,5 "$meta_file" > "$sorted_file"

if [[ $list_only -eq 1 ]]; then
    printf 'updated\ttitle\tpath\n'
    while IFS=$'\t' read -r _ _ updated title relative; do
        printf '%s\t%s\t%s\n' "$updated" "$title" "$relative"
    done < "$sorted_file"
    exit 0
fi

selected_id=
if [[ -n $select_relative ]]; then
    while IFS=$'\t' read -r candidate_id _ _ _ candidate_relative; do
        if [[ $candidate_relative == "$select_relative" ]]; then
            selected_id=$candidate_id
            break
        fi
    done < "$meta_file"
    [[ -n $selected_id ]] \
        || ops_die "note is not present in the knowledge root: $select_relative"
else
    ops_need "$OPS_FZF_BIN"
    ops_fzf_base "KB CHEATSHEET INDEX / ${note_count} RECORDS" "$note_count"
    if (( OPS_COLUMNS < 82 )); then
        header='UPDATED     TITLE'
        while IFS=$'\t' read -r id _ updated title relative; do
            printf '%s\t%s %s %s\t%-11s %s\n' \
                "$id" "$updated" "$title" "$relative" "$updated" "$title"
        done < "$sorted_file" > "$choices_file"
    else
        header='UPDATED     TITLE                                PATH'
        while IFS=$'\t' read -r id _ updated title relative; do
            printf '%s\t%s %s %s\t%-11s %-36s %s\n' \
                "$id" "$updated" "$title" "$relative" \
                "$updated" "$title" "$relative"
        done < "$sorted_file" > "$choices_file"
    fi
    header="${header}"$'\n''ENTER OPEN  CTRL-/ PREVIEW  ESC CANCEL'

    query=
    if (( query_count > 0 )); then
        for query_part in "${queries[@]}"; do
            query="${query}${query:+ }${query_part}"
        done
    fi
    self_path="$script_dir/$(basename -- "${BASH_SOURCE[0]}")"
    printf -v preview_command '%q --_preview {1}' "$self_path"
    export KB_META_FILE="$meta_file"
    export KB_PREVIEW_DIR="$preview_dir"
    export OPS_COLOR=1

    fzf_args=(
        "${OPS_FZF_BASE[@]}"
        '--delimiter=\t'
        '--with-nth=3'
        '--nth=1,2'
        '--prompt=FILTER / '
        "--header=$header"
        "--query=$query"
        "--preview=$preview_command"
        '--preview-label= CHEATSHEET RECORD '
        "--preview-window=$OPS_PREVIEW_WINDOW"
        '--bind=ctrl-/:toggle-preview'
    )
    set +e
    selected_line=$(FZF_DEFAULT_OPTS='' \
        "$OPS_FZF_BIN" "${fzf_args[@]}" < "$choices_file")
    fzf_status=$?
    set -e
    case $fzf_status in
        0) ;;
        1|130) exit 0 ;;
        *) ops_die "fzf exited with status $fzf_status" ;;
    esac
    [[ -n $selected_line ]] || exit 0
    selected_id=${selected_line%%$'\t'*}
fi

[[ $selected_id =~ ^[0-9]+$ && -f $preview_dir/$selected_id ]] \
    || ops_die 'picker returned a note outside the knowledge index'
selected_path=$(readlink "$preview_dir/$selected_id")
[[ -f $selected_path ]] || ops_die "selected note disappeared: $selected_path"

if [[ $print_only -eq 1 ]]; then
    printf '%s\n' "$selected_path"
    exit 0
fi

editor=${KB_EDITOR:-${VISUAL:-${EDITOR:-nvim}}}
if ! command -v "$editor" >/dev/null 2>&1; then
    case $editor in
        *[[:space:]]*)
            ops_die 'KB_EDITOR/VISUAL/EDITOR must be one executable, not a command string; use a wrapper for arguments'
            ;;
        *) ops_die "missing required command: $editor" ;;
    esac
fi
ops_tmp_cleanup
unset KB_META_FILE KB_PREVIEW_DIR OPS_COLOR
exec "$editor" "$selected_path"
